{
  "name": "ai-copilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "dev": "concurrently -k -n ui,api -c green,cyan \"npm:dev:ui\" \"npm:dev:api\"",
    "dev:ui": "vite",
    "dev:api": "node --env-file=.env/agent-dev.env agent-api/server.js",
    "generate:a2a-cards": "node agent-api/generate-a2a-cards.js",
    "deploy:ai-copilot-backend": "docker compose -f docker/docker-compose.ai-copilot-backend-yaml up -d --build",
    "run:ai-copilot-backend": "docker compose -f docker/docker-compose.ai-copilot-backend-yaml up -d",
    "stop:ai-copilot-backend": "docker compose -f docker/docker-compose.ai-copilot-backend-yaml down",
    "deploy:ai-copilot-ui": "docker compose -f docker/docker-compose.ai-copilot-ui-yaml up -d --build",
    "run:ai-copilot-ui": "docker compose -f docker/docker-compose.ai-copilot-ui-yaml up -d",
    "stop:ai-copilot-ui": "docker compose -f docker/docker-compose.ai-copilot-ui-yaml down",
    "deploy:ai-copilot": "npm run deploy:ai-copilot-backend && npm run deploy:ai-copilot-ui",
    "run:ai-copilot": "npm run run:ai-copilot-backend && npm run run:ai-copilot-ui",
    "stop:ai-copilot": "npm run stop:ai-copilot-ui && npm run stop:ai-copilot-backend",
    "deploy:a2a-inspector": "docker compose -f docker/docker-compose.a2a-inspector.yml up -d --build",
    "run:a2a-inspector": "docker compose -f docker/docker-compose.a2a-inspector.yml up -d",
    "stop:a2a-inspector": "docker compose -f docker/docker-compose.a2a-inspector.yml down",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "secrets:scan": "gitleaks detect --source . --config .gitleaks.toml --no-banner --redact --verbose",
    "secrets:scan:staged": "gitleaks protect --staged --config .gitleaks.toml --no-banner --redact --verbose",
    "test:e2e": "playwright test",
    "agent-api": "npm run dev:api"
  },
  "dependencies": {
    "@langchain/core": "^0.3.58",
    "@langchain/langgraph": "^0.3.0",
    "@langchain/openai": "^0.5.13",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "langchain": "^0.3.31",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
