OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_X_TITLE=Axomoxoa AI Copilot
AGENT_API_PORT=8787

# OTEL tracing exporter mode: console | otlp | none
OTEL_TRACES_EXPORTER=console

# Optional for OTLP mode
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-token

# Optional Atlassian MCP endpoint controls
# Explicit override (all environments):
# ATLASSIAN_MCP_URL=http://127.0.0.1:8000/mcp
# Environment-aware fallback inputs (used when ATLASSIAN_MCP_URL is unset):
# ATLASSIAN_MCP_URL_LOCAL=http://127.0.0.1:8000/mcp
# ATLASSIAN_MCP_URL_DOCKER=http://host.docker.internal:8000/mcp
# RUNNING_IN_DOCKER=true
